# TqSdk Account
TQ_USERNAME=
TQ_PASSWORD=
TQ_BROKER=
TQ_ACCOUNT_ID=
TQ_TRADE_PWD=

# Runtime mode: backtest | kq | live
TQ_MODE=backtest

# PostgreSQL
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant_pass
POSTGRES_DB=quantdb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# InfluxDB
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=quant_token
INFLUXDB_ORG=quant
INFLUXDB_BUCKET=market_data

# Rollover strategy: independent | spread_adjust
ROLLOVER_STRATEGY=independent

# Redis (for Celery)
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
